{
  "name": "@mobiman/vector",
  "version": "1.1.1",
  "description": "A meta-prompting, context engineering, and spec-driven development system for iOS app creation",
  "bin": {
    "vector": "bin/install.cjs"
  },
  "files": [
    "bin",
    "commands",
    "core",
    "agents",
    "hooks/dist",
    "scripts"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "meta-prompting",
    "context-engineering",
    "spec-driven-development",
    "gemini",
    "gemini-cli",
    "codex",
    "codex-cli"
  ],
  "author": "Mobiman",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mobiman/core.git"
  },
  "homepage": "https://github.com/mobiman/core",
  "bugs": {
    "url": "https://github.com/mobiman/core/issues"
  },
  "engines": {
    "node": ">=16.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "c8": "^11.0.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "prepublishOnly": "npm run build",
    "test": "tsc --project tsconfig.json && node scripts/run-tests.cjs",
    "test:coverage": "tsc --project tsconfig.json && c8 --check-coverage --lines 70 --reporter text --include 'core/bin/lib/*.cjs' --exclude 'tests/**' --all node scripts/run-tests.cjs"
  }
}
