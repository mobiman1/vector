{
  "compilerOptions": {
    "target": "ES2021",
    "module": "Node16",
    "moduleResolution": "node16",
    "sourceMap": true,
    "outDir": ".",
    "rootDir": ".",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "checkJs": false,
    "declaration": true,
    "declarationMap": true,
    "skipLibCheck": true
  },
  "include": [
    "core/bin/**/*.cts",
    "bin/**/*.cts",
    "hooks/**/*.cts",
    "scripts/**/*.cts",
    "tests/**/*.cts"
  ],
  "exclude": [
    "node_modules",
    "hooks/dist",
    "**/*.d.cts"
  ]
}
